# ======================================
# EXEMPLO DE ARQUIVO .env
# ======================================
# Copie este arquivo para ".env" e configure com seus valores reais
# cp .env.example .env

# ===== BANCO DE DADOS =====
# Tipo de cliente (mysql2, postgresql, sqlite3)
DB_CLIENT=mysql2

# Credenciais e host do banco
DB_HOST=localhost
DB_PORT=3306
DB_USER=lepapon_user
DB_PASSWORD=sua_senha_segura_aqui
DB_NAME=lepapon_unified_db

# Alternativa: usar uma connection string única (descomente se usar isso)
# DATABASE_URL=mysql2://usuario:senha@localhost:3306/lepapon_unified_db

# Configurações SSL (para bancos de dados remotos)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED_FALSE=false

# Pool de conexões
DB_POOL_MIN=0
DB_POOL_MAX=10

# Tabela e diretório de migrações
DB_MIGRATIONS_TABLE=knex_migrations
DB_MIGRATIONS_DIR=./migrations

# ===== SERVIDOR =====
# Porta da aplicação
PORT=3000

# Ambiente (development, production, staging)
NODE_ENV=production

# CORS - de qual origem aceitar requisições
CORS_ORIGIN=*

# ===== WHATSAPP FLOW (CRIPTOGRAFIA) =====
# Caminho para arquivo de chave privada RSA (gerada pelo Meta)
# Pode ser caminho absoluto ou relativo ao diretório backend/
WHATSAPP_FLOW_PRIVATE_KEY_PATH=./keys/whatsapp_flow_private_key.pem

# Chave secreta da aplicação Meta (App Secret)
# Obtém em: https://developers.facebook.com/apps/seu-app-id/settings/basic
WHATSAPP_APP_SECRET=seu_app_secret_meta_aqui

# ===== WHATSAPP API (META) =====
# Token de acesso para fazer requisições à API
# Obtém em: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=EAABs4K2G...seu_token_de_acesso_aqui

# ID do número de telefone WhatsApp Business
# Obtém em: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_PHONE_NUMBER_ID=seu_numero_id_aqui

# Token para validação de webhooks
# Você escolhe um valor qualquer, use algo seguro
WHATSAPP_VERIFY_TOKEN=seu_token_verificacao_webhook_aqui

# Versão da API Graph do Meta
WHATSAPP_GRAPH_VERSION=20.0

# ===== TEMPLATES DO WHATSAPP (OPCIONAL) =====
# Nome do template pre-aprovado
WHATSAPP_TEMPLATE_NAME=sua_template_name

# Idioma do template (pt_BR, en_US, etc)
WHATSAPP_TEMPLATE_LANG=pt_BR

# Texto do rodapé
WHATSAPP_TEMPLATE_FOOTER_TEXT=Lepapon

# Configurações de botão
WHATSAPP_TEMPLATE_BUTTON_SUBTYPE=flow
WHATSAPP_TEMPLATE_BUTTON_INDEX=0
WHATSAPP_TEMPLATE_BUTTON_PAYLOAD=seu_payload_aqui
WHATSAPP_TEMPLATE_BUTTON_URL_TEXT=Abrir

# Tipos de destinatário
WHATSAPP_TEMPLATE_RECIPIENT_TYPE=individual
WHATSAPP_TEXT_RECIPIENT_TYPE=individual

# Concorrência de envio de mensagens
WHATSAPP_OUTBOUND_CONCURRENCY=2
WHATSAPP_OUTBOUND_MAX=2000

# ===== FRONTEND - MODO DEMONSTRAÇÃO =====
# IMPORTANTE: Apenas para desenvolvimento!
# Em produção, defina como 'false' e implemente autenticação real no backend

# Ativar modo demonstração (true/false) - DESABILITAR EM PRODUÇÃO
VITE_DEMO_MODE=false

# API Backend para autenticação
VITE_API_URL=http://localhost:3000/api

# ===== Credenciais de demonstração (apenas para modo demo) =====
# Apenas usadas se VITE_DEMO_MODE=true
VITE_DEMO_USER_ADMIN=admin
VITE_DEMO_PASS_ADMIN=admin123

VITE_DEMO_USER_OPERADOR=operador
VITE_DEMO_PASS_OPERADOR=op123

VITE_DEMO_USER_CAIXA=caixa
VITE_DEMO_PASS_CAIXA=caixa123

# ===== DEPLOY (PM2 / CI-CD) =====
# Usuário SSH para deploy
DEPLOY_USER=deploy

# Host do servidor para deploy
DEPLOY_HOST=seu-servidor.com

# ===== NOTAS IMPORTANTES =====
#
# 1. NUNCA commit este arquivo em .env com dados reais!
#    Use .env.example como modelo e .env para valores reais.
#
# 2. Variáveis de ambiente em nuvem (Google Cloud, AWS, Heroku):
#    Configure via painel da plataforma ou via CLI
#
# 3. Para gerar chave privada do WhatsApp:
#    Obtenha em https://developers.facebook.com/docs/whatsapp/flows
#    Salve em ./keys/whatsapp_flow_private_key.pem (relativo a backend/)
#
# 4. Para testar se todas as variáveis estão configuradas:
#    Execute: node backend/scripts/check-env.js
#
# 5. Segurança:
#    - Nunca compartilhe tokens ou chaves secretas
#    - Use .gitignore para proteger .env
#    - Rotacione tokens regularmente
#    - Use variáveis de ambiente do SO em produção
