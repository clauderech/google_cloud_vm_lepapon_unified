{
  "name": "whatsapp-meta-webhook",
  "version": "1.0.0",
  "private": true,
  "description": "Webhook simples para WhatsApp Cloud API (Meta)",
  "main": "processwhatsapp.js",
  "type": "commonjs",
  "scripts": {
    "start": "node processwhatsapp.js",
    "migrate": "knex migrate:latest",
    "pm2:start": "pm2 start ecosystem.config.js --only webhook-whatsapp-meta",
    "pm2:restart": "pm2 restart webhook-whatsapp-meta --update-env",
    "pm2:logs": "pm2 logs webhook-whatsapp-meta --lines 100"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "knex": "^3.1.0",
    "mysql2": "^3.13.0"
  },
  "engines": {
    "node": ">=18"
  }
}
